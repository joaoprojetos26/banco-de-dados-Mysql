atividade50
CREATE TABLE RelatorioFinal AS
SELECT 
CONCAT(e.FirstName, ' ', e.LastName) AS NomeCompleto,
COUNT(o.OrderID) AS TotalEncomendas
FROM Employees e
JOIN Orders o ON e.EmployeeID = o.EmployeeID
GROUP BY e.EmployeeID, e.FirstName, e.LastName
HAVING COUNT(o.OrderID) > 5
ORDER BY TotalEncomendas DESC
LIMIT 3;
