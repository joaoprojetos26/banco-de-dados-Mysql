atividade 1
SELECT  CONCAT(ProductName AS '-R$' Price *2) AS resultado
from Products
LIMIT 10;

atividade 2
SELECT CONCAT( 'O produto/' , ProductName , '/custa/' , Price , '/euros/') AS 'Descricao'
FROM Products
ORDER BY Price ASC
LIMIT 5;

atividade 3
SELECT CONCAT( 'Encomenda', OrderDetailID, ' ','tem total de', Quantity *10) AS 'Descricao'
from OrderDetails
limit 15;

atividade 4
SELECT 
    CONCAT(FirstName, ' ', LastName, ' - Funcionario Senai') AS 'NomeCompleto/funcionario'
FROM Employees
LIMIT 3;

atvidade 5
SELECT 
ProductName AS Produto,
Price AS Preco,
Price * 0.85 AS Desconto
FROM Products
ORDER BY Price DESC
LIMIT 8;

atividade 6
SELECT 
CONCAT(CustomerName, ' : ', City) AS 'Cidade Do Cliente'
FROM Customers
ORDER BY CustomerName ASC
LIMIT 12;

atividade7
SELECT OrderDetailID AS ID ,
CONCAT('Quantidade: ', Quantity, ' | Diferenca: ', 100 - Quantity) AS Resultado
FROM OrderDetails
LIMIT 20;

atividade8
SELECT 
    CONCAT(CategoryName, ' : ', Description) AS 'Produtos E Descricao'
FROM Categories
LIMIT 5;

atividade9
SELECT 
CONCAT(ProductName ,' ','preco :R$', Price * 50) AS  Custo_50_Unidades
FROM Products
LIMIT 10;

atividade10
SELECT 
CONCAT(Address, ', ', City, ' : ', PostalCode) AS 'endereco Completo'
FROM Customers
LIMIT 25;

atividade11
SELECT City AS Cidade,
COUNT(*) AS TotalClientes
FROM Customers
GROUP BY Cidade
ORDER BY TotalClientes DESC
LIMIT 5;

atividade12
SELECT 
    CategoryID AS ID,
    COUNT(*) AS TodosProdutos
FROM Products
GROUP BY ID
LIMIT 3;

atividade13
SELECT 
    EmployeeID AS 'ID Funcionario',
    COUNT(*) AS TotalEncomendas
FROM Orders
GROUP BY EmployeeID
ORDER BY TotalEncomendas DESC

atividade14
SELECT 
    Country AS Pais,
    COUNT(*) AS TotalFornecedores
FROM Suppliers
GROUP BY Country
LIMIT 10;

atividade15
SELECT 
OrderID AS ID,
COUNT(DISTINCT ProductID) AS ProdutosDiferentes
FROM OrderDetails
GROUP BY OrderID
LIMIT 15;

atividade16
SELECT 
City AS Cidade,
COUNT(*) AS TotalDetransportadoras
FROM  Customers
GROUP BY City 
LIMIT 2;

